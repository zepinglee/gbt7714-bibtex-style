%
% Õ”éµ×£ label õĖŁµ£ēõĖŁµŗ¼ÕÅĘŌĆ£[ŌĆØ’╝īÕłåÕł½ńö©Õż¦µŗ¼ÕÅĘõ┐ØµŖżĶĄĘµØź’╝īķś▓µŁó \cs{bibitem} ÕżäńÉåÕć║ķöÖŃĆé
% ÕÅ”Õż¢õĖ║õ║åÕģ╝Õ«╣ \pkg{bibunits}’╝īŌĆ£name(year)fullnameŌĆØ ńÜäµ»ÅõĖĆķĪ╣ķāĮĶ”üÕłåÕł½õ┐ØµŖżĶĄĘµØź’╝ī
% ÕÅéĶĆā \href{https://github.com/tuna/thuthesis/issues/630}{tuna/thuthesis/\#630}ŃĆé
%    \begin{macrocode}
FUNCTION {calc.label}
{ calc.short.authors
  short.list "]" contains
    { "{" short.list * "}" * }
    { short.list }
  if$
  "("
  *
  format.year duplicate$ empty$
  short.list key field.or.null = or
     { pop$ "" }
     'skip$
  if$
  duplicate$ "]" contains
    { "{" swap$ * "}" * }
    'skip$
  if$
  *
  'label :=
}

