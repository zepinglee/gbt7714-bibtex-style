  \def\cstr{\begingroup \urlstyle{same}\Url}
\else
  \def\doi#1{\href{https://doi.org/#1}{\nolinkurl{#1}}}
  \def\cstr#1{\href{https://cstr.cn/#1}{\nolinkurl{#1}}}
\fi

