}

% 5.1.2 由双姓组合（并列姓氏）作为姓氏部分，双姓中间加连接号。
@book{zheng-li,
  author = {Zheng-Li, Shufang}
}

% The Unicode character doesn't work.
@book{lü,
  author = {Lü, Heping}
}

@book{lyu,
  author = {Lyu, Heping}
}
