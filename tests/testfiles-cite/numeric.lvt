% 9.2.1.1 顺序编码制是按正文中引用的文献出现的先后顺序连续编码，将序号置于方括号中。
引用\citep{zhang1984}测试\par
引用\citet{zhang1984}测试\par

% 9.2.1.2 同一处引用多篇文献时，应将各篇文献的序号在方括号内全部列出，各序号间用“,”。
% 如遇连续序号，起讫序号 间用短横线连接。
引用\citep{zhang1984, zhang1985}测试\par
引用\citep{zhang1986, zhang1984}测试\par
引用\citet{zhang1984, zhang1985}测试\par
引用\citet{zhang1986, zhang1984}测试\par

% 9.2.1.3 多次引用同一著者的同一文献时，在正文中标注首次引用的文献序号，
% 并在序号的“[]”外著录引文页码。
引用\citep[42]{zhang1984}测试\par
引用\citet[42]{zhang1984}测试\par

% 《GB/T 7714—2025〈信息与文献参考文献著录规则〉的修订亮点、规则新点及实施疑点》3.6.6)
% 序号也可作为行文语句的组成部分。
引用\parencite[42]{zhang1984}测试\par

% 测试 \citeauthor 与后续文字的间隙
% <https://github.com/zepinglee/gbt7714-bibtex-style/issues/120>
引用\citeauthor{zhang1984}测试\par

引用\citep[参见][42]{zhang1984}测试\par


% 英文测试
\null\par

% 9.2.1.1 顺序编码制是按正文中引用的文献出现的先后顺序连续编码，将序号置于方括号中。
Citation\citep{doe1984} test\par
Citation \citet{doe1984} test\par

% 9.2.1.2 同一处引用多篇文献时，应将各篇文献的序号在方括号内全部列出，各序号间用“,”。
% 如遇连续序号，起讫序号 间用短横线连接。
Citation\citep{doe1984, doe1985} test\par
Citation\citep{doe1986, doe1984} test\par
Citation \citet{doe1984, doe1985} test\par
Citation \citet{doe1986, doe1984} test\par

% 9.2.1.3 多次引用同一著者的同一文献时，在正文中标注首次引用的文献序号，
% 并在序号的“[]”外著录引文页码。
Citation\citep[42]{doe1984} test\par
Citation \citet[42]{doe1984} test\par

% 《GB/T 7714—2025〈信息与文献参考文献著录规则〉的修订亮点、规则新点及实施疑点》3.6.6)
% 序号也可作为行文语句的组成部分。
Citation \parencite[42]{doe1984} test\par

Citation (\citeauthor{doe1984}) test\par

Citation \citep[see][42]{doe1984} test\par

