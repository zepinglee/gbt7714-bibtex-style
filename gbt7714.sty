    gbt7714-2005-numerical = gbt7714-2005-numeric ,
    gbt7714-author-year = gbt7714-authoryear ,
    gbt7714-numerical = gbt7714-numeric ,
  }

\cs_set_nopar:Npn \bibliographystyle #1
  {
    \prop_get:NnNTF \c__gbt_deprecated_style_name_prop {#1} \l_tmpa_tl
      {
