        \file_if_exist:nTF { #1 .bst }
          { \__gbt_original_bib_style:n {#1} }
          { \exp_args:NV \__gbt_original_bib_style:n \l_tmpa_tl }
      }
      { \__gbt_original_bib_style:n {#1} }
  }

